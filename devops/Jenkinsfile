pipeline {
  agent any

  stages {
    stage('GIT CLONE STAGE') {
        steps {
            git branch: 'main', url: 'https://github.com/jehadkalifah/mono-repo-test.git/'
            sh 'echo List the repository directories'
            sh 'ls -ltr apps || true'
        }
    }

    stage('Build all services') {
        steps {
            script {
                // obtain a list of sub‑directories under apps/
                def services = sh(script: "ls -1 apps 2>/dev/null || true", returnStdout: true)
                                     .trim()
                                     .split("\\r?\\n")
                                     .findAll { it }   // drop empty lines

                services.each { svc ->
                    def svcPath = "apps/${svc}"

                    // optional: only run if something under that folder changed
                    def changed = sh(
                        script: "git diff --name-only HEAD~1 | grep -q '^${svcPath}/' && echo yes || echo no",
                        returnStdout: true
                    ).trim() == 'yes'

                    if (!changed) {
                        echo "no changes in ${svcPath}, skipping"
                        return
                    }

                    // create a real stage for every service
                    stage("Build ${svc}") {
                        dir(svcPath) {
                            catchError(buildResult: 'FAILURE', stageResult: 'FAILURE') {
                                sh "echo Building ${svc}…"
                                // your actual build commands go here
                            }
                        }
                    }
                }
            }
        }
    }
  }
}
