pipeline {

    environment {
        // Pipeline Variables
        ROOT_GIT_APPS_DIR     = "apps"  
        ROOT_LOCAL_APPS_DIR   = "/var/lib/jenkins"
        GENERAL_SCRIPT_FILE   = "deployScript.sh"  


        APP_NAME              = "commercial"

    } //environment

    tools {
        nodejs 'node24'
    }

    agent any

    stages {
        stage('BUILDING STAGES FOR ALL SERVICES') {
            steps {
                script {
                    // obtain a list of sub‑directories under apps/ (ignore any Jenkins @tmp entries)
                    def services = sh(script: "ls -1 ${ROOT_GIT_APPS_DIR} 2>/dev/null | grep -v \'@tmp\$\' || true", returnStdout: true)
                                        .trim()
                                        .split("\\r?\\n") 
                                        .findAll { it }

                    echo "Found services: ${services}"                                        

                    services.each { svc ->
                        def svcPath = "${ROOT_GIT_APPS_DIR}/${svc}"

                        // only run if something under that folder changed
                        // compare current commit against previous; handle edge cases gracefully
                        def changedFiles = sh(
                            script: "git diff --name-only HEAD~1 HEAD -- ${svcPath} 2>/dev/null | head -1",
                            returnStdout: true
                        ).trim()

                        def changed = changedFiles.length() > 0

                        if (!changed) {  
                            echo "no changes in ${svcPath}, skipping" 
                            return 
                        } //if

                        // create a real stage for every service
                        stage("BUILDING ${svc.toUpperCase()} STAGE") {
                            def commitId = sh(script: "git log -n1 --format=%H -- ${svcPath} | cut -c1-8", returnStdout: true).trim()
                            def stageResult = 'SUCCESS'  // Default to success
                            dir(svcPath) {
                                catchError(buildResult: 'FAILURE', stageResult: 'FAILURE') { 
                                    sh "echo Building ${svc} at commit ${commitId}…"  
                                    sh "if [ -f ${GENERAL_SCRIPT_FILE} ]; then chmod +x ${GENERAL_SCRIPT_FILE} && ./${GENERAL_SCRIPT_FILE} ${svc} ${BRANCH_NAME} ${ROOT_LOCAL_APPS_DIR} ${WORKSPACE}; fi"  
                                    // currentBuild.result = 'SUCCESS'  // Explicitly set to SUCCESS
                                    // If we reach here without exception, mark as success
                                } //catchError
                                echo "currentBuild.result: ${currentBuild.result}"
                                stageResult = currentBuild.result ?: 'SUCCESS'
                                echo "stageResult: ${stageResult}"
                            } //dir
                        } //stage
                    } //services.each
                } //script   
            } //steps
        } //stage
    } // stages   

    post {  
        cleanup {
          //cleans workspace  
          cleanWs()   
        } //cleanup
    } //post    

} //pipeline